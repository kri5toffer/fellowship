// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum FieldType {
  TEXT
  NUMBER
  CHECKBOX
  DATE
}

// User model for audit tracking
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  avatarUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdBases   Base[]   @relation("BaseCreatedBy")
  createdTables  Table[]  @relation("TableCreatedBy")
  createdColumns Column[] @relation("ColumnCreatedBy")
  createdRows    Row[]    @relation("RowCreatedBy")
}

model Base {
  id           String   @id @default(cuid())
  baseName     String
  description  String?
  color        String   @default("#1d7c6a")
  displayOrder Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  createdById String?
  createdBy   User?   @relation("BaseCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  tables Table[]

  @@index([createdById])
}

model Table {
  id           String   @id @default(cuid())
  tableName    String
  displayOrder Int      @default(0)
  baseId       String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Audit field
  createdById String?
  createdBy   User?   @relation("TableCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  base    Base     @relation(fields: [baseId], references: [id], onDelete: Cascade)
  columns Column[]
  rows    Row[]

  @@unique([baseId, tableName])
  @@index([baseId])
  @@index([createdById])
}

model Column {
  id           String    @id @default(cuid())
  columnName   String
  fieldType    FieldType @default(TEXT)
  displayOrder Int       @default(0)
  tableId      String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  createdById String?
  createdBy   User?   @relation("ColumnCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  table Table  @relation(fields: [tableId], references: [id], onDelete: Cascade)
  cells Cell[]

  @@unique([tableId, columnName])
  @@index([tableId])
  @@index([createdById])
}

model Row {
  id           String   @id @default(cuid())
  displayOrder Int      @default(0)
  tableId      String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  createdById String?
  createdBy   User?   @relation("RowCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  table Table  @relation(fields: [tableId], references: [id], onDelete: Cascade)
  cells Cell[]

  @@index([tableId])
  @@index([createdById])
}

model Cell {
  id        String   @id @default(cuid())
  cellValue String?
  rowId     String
  columnId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  row    Row    @relation(fields: [rowId], references: [id], onDelete: Cascade)
  column Column @relation(fields: [columnId], references: [id], onDelete: Cascade)

  @@unique([rowId, columnId])
  @@index([columnId])
  @@index([rowId])
}
